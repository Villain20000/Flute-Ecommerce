rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "dermengr@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidWishlist(data) {
      return data.keys().hasAll(['userId', 'productIds', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.productIds is list &&
             data.updatedAt is string;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'image']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.image is string &&
             (!('description' in data) || (data.description is string && data.description.size() < 2000)) &&
             (!('featured' in data) || data.featured is bool) &&
             (!('rating' in data) || (data.rating is number && data.rating >= 0 && data.rating <= 5)) &&
             (!('specs' in data) || data.specs is list) &&
             (!('createdAt' in data) || data.createdAt is string);
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'totalAmount', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.items is list && data.items.size() > 0 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
             (!('paymentMethod' in data) || data.paymentMethod is string) &&
             (!('paymentId' in data) || data.paymentId is string) &&
             data.createdAt is string;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Products: Publicly readable, only admins can write
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidProduct(request.resource.data);
    }

    // Orders: Users can read/write their own orders, admins can read/write all
    match /orders/{orderId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      allow delete: if isAdmin();
    }

    // Users: Users can read/write their own profile, admins can read all
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.role == 'user';
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }

    // Wishlist: Users can read/write their own wishlist
    match /wishlist/{wishlistId} {
      allow read: if isOwner(wishlistId) || isAdmin();
      allow create, update: if isOwner(wishlistId) && isValidWishlist(request.resource.data);
      allow delete: if isOwner(wishlistId) || isAdmin();
    }
  }
}
